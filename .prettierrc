{
    "plugins": ["prettier-plugin-astro"],
    "semi": false,
    "printWidth": 130,
    "singleQuote": false,
    "trailingComma": "none",
    "tabWidth": 4,
    "useTabs": false,
    "overrides": [
        {
            "files": "*.astro",
            "options": {
                "parser": "astro"
            }
        }
    ]
}
